# Variáveis de Ambiente - TPizzaria com Supabase

# ============================================
# DESENVOLVIMENTO (JSON Server)
# ============================================
VITE_SUPABASE_URL=http://localhost:3000
VITE_SUPABASE_KEY=dev-key
VUE_APP_API_BASE_URL=http://localhost:3000

# ============================================
# PRODUÇÃO (Supabase)
# ============================================
# Copiar valores do Supabase Dashboard > Settings > API

# URL do seu projeto Supabase
# Exemplo: https://abc123.supabase.co
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave pública (anon key)
# Encontrar em: Settings > API > anon public key
# Começa com: eyJhbGc...
VITE_SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL da API para ambiente de produção
VUE_APP_API_BASE_URL=https://seu-projeto.supabase.co

# ============================================
# RENDER (se usar como backend)
# ============================================
# VITE_API_URL=https://seu-app-backend.onrender.com
